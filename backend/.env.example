PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/cse_events

# JWT
JWT_SECRET=replace_with_long_random_secret

# Frontend URL (CORS + email links)
CLIENT_URL=http://localhost:5173

# API base URL (used in certificate verification QR links)
API_URL=http://localhost:5000

# Cloudinary (optional - if not set, files are stored in /uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (Nodemailer SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="CSE Events <your_email@gmail.com>"

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

